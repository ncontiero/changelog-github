{
  "name": "@ncontiero/changelog-github",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@11.15.1",
  "description": "A custom changelog entry generator for Changesets on GitHub. Features advanced exclusion options, summary overrides, and links to commits, PRs, and authors.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "homepage": "https://github.com/ncontiero/changelog-github#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncontiero/changelog-github.git"
  },
  "bugs": {
    "url": "https://github.com/ncontiero/changelog-github/issues"
  },
  "keywords": [
    "changelog",
    "github",
    "changeset",
    "release",
    "automation",
    "release-notes",
    "versioning"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "pnpm build && changeset version",
    "pub:release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@changesets/get-github-info": "^0.8.0"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.1",
    "@changesets/parse": "0.4.3",
    "@changesets/types": "6.1.0",
    "@ncontiero/eslint-config": "8.4.3",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "tsdown": "0.22.12",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
