{
  "name": "@ncontiero/changelog-github",
  "type": "module",
  "version": "2.1.3",
  "packageManager": "pnpm@10.33.2",
  "description": "A changelog entry generator for changeset on GitHub with links to commits, PRs and optionally users.",
  "author": {
    "name": "Nicolas Contiero",
    "url": "https://github.com/ncontiero"
  },
  "license": "MIT",
  "homepage": "https://github.com/ncontiero/changelog-github#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncontiero/changelog-github.git"
  },
  "bugs": {
    "url": "https://github.com/ncontiero/changelog-github/issues"
  },
  "keywords": [
    "changelog",
    "github",
    "changeset",
    "release",
    "automation",
    "release-notes",
    "versioning"
  ],
  "exports": "./dist/index.cjs",
  "main": "./dist/index.cjs",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "release": "pnpm build && changeset version",
    "pub:release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@changesets/get-github-info": "^0.8.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@changesets/parse": "^0.4.3",
    "@changesets/types": "^6.1.0",
    "@ncontiero/eslint-config": "7.2.0",
    "@types/node": "^25.6.0",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
